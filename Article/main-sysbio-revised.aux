\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Simulation-based validation of the OBD model.} {\color  {blue} Results of the simulation-based calibration study on 1000 datasets simulated under the OBD model. (a)~Truth recovery proportions: the proportion of datasets for which the true parameter value falls within posterior credible intervals of increasing width (from 5\% to 95\%). A well-calibrated model produces points along the diagonal. (b)~Estimation error, measured as the normalized squared error $(\mathaccent "0362{\theta } - \theta )^2 / \theta ^2$ (where $\mathaccent "0362{\theta }$ is the posterior median and $\theta $ the true value), plotted against the number of tips in the reconstructed phylogeny.}\relax }}{18}{figure.caption.10}\protected@file@percent }
\newlabel{fig:cobd-validation}{{3}{18}{\textbf {Simulation-based validation of the OBD model.} \revised {Results of the simulation-based calibration study on 1000 datasets simulated under the OBD model. (a)~Truth recovery proportions: the proportion of datasets for which the true parameter value falls within posterior credible intervals of increasing width (from 5\% to 95\%). A well-calibrated model produces points along the diagonal. (b)~Estimation error, measured as the normalized squared error $(\hat {\theta } - \theta )^2 / \theta ^2$ (where $\hat {\theta }$ is the posterior median and $\theta $ the true value), plotted against the number of tips in the reconstructed phylogeny.}\relax }{figure.caption.10}{}}
\newlabel{fig:cobd-validation@cref}{{[figure][3][]3}{[1][17][]18}}
