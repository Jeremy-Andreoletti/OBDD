\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces \textbf  {Summary of the different diversification models and corresponding analyses on the cetacean dataset.} The table shows for each analysis the number of model parameters, characteristics of the cetacean data subset included in the inference - number of tips, {\color  {blue} coded} fossils and {\color  {blue} uncoded} occurrences - and the computational efficiency. Models include homogeneous variants (BD, FBD, OBD, OBD-noF) and diffusion-based variants (BDD, FBDD, OBDD, OBDD-noF) ; the suffix -noF indicates models run without {\color  {blue} coded} fossils in the phylogeny, retaining only {\color  {blue} uncoded} occurrences. MCMC durations are averaged over 5 replicates. Effective sample sizes (ESS) are averaged over replicates and parameters.\relax }}{16}{table.caption.8}\protected@file@percent }
\newlabel{tab:models}{{2}{16}{\textbf {Summary of the different diversification models and corresponding analyses on the cetacean dataset.} The table shows for each analysis the number of model parameters, characteristics of the cetacean data subset included in the inference - number of tips, \revised {coded} fossils and \revised {uncoded} occurrences - and the computational efficiency. Models include homogeneous variants (BD, FBD, OBD, OBD-noF) and diffusion-based variants (BDD, FBDD, OBDD, OBDD-noF) ; the suffix -noF indicates models run without \revised {coded} fossils in the phylogeny, retaining only \revised {uncoded} occurrences. MCMC durations are averaged over 5 replicates. Effective sample sizes (ESS) are averaged over replicates and parameters.\relax }{table.caption.8}{}}
\newlabel{tab:models@cref}{{[table][2][]2}{[1][16][]16}}
