\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Simulation-based validation of the OBDD model.} {\color  {blue} Results of the simulation-based calibration study on 500 datasets simulated under the OBDD model. (a)~Truth recovery proportions as in Fig.~\ref  {fig:cobd-validation}. (b)~Normalized squared estimation error as a function of tree size. The colour gradient indicates the number of simulated {\color  {blue} uncoded} occurrences.}\relax }}{19}{figure.caption.11}\protected@file@percent }
\newlabel{fig:obdd-validation}{{4}{19}{\textbf {Simulation-based validation of the OBDD model.} \revised {Results of the simulation-based calibration study on 500 datasets simulated under the OBDD model. (a)~Truth recovery proportions as in Fig.~\ref {fig:cobd-validation}. (b)~Normalized squared estimation error as a function of tree size. The colour gradient indicates the number of simulated \revised {uncoded} occurrences.}\relax }{figure.caption.11}{}}
\newlabel{fig:obdd-validation@cref}{{[figure][4][]4}{[1][17][]19}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Scaling of MCMC runtime with tree size for the OBDD model.} Each point corresponds to one of the datasets used for the simulation-based model validation procedure, from which we recorded the number of tips in the reconstructed phylogeny (including fossil tips) and the runtime for the set number of iterations. The colour gradient indicates the number of simulated {\color  {blue} uncoded} occurrences. {\color  {blue} Note that these runtimes reflect an ideal scenario in which datasets are generated directly under the model, producing relatively smooth diversification dynamics and fewer augmented branches to simulate. Empirical datasets with more complex histories (e.g.\ cetaceans) require substantially longer runtimes; see Table~\ref  {tab:models} for empirical values.}\relax }}{20}{figure.caption.12}\protected@file@percent }
\newlabel{fig:running-time}{{5}{20}{\textbf {Scaling of MCMC runtime with tree size for the OBDD model.} Each point corresponds to one of the datasets used for the simulation-based model validation procedure, from which we recorded the number of tips in the reconstructed phylogeny (including fossil tips) and the runtime for the set number of iterations. The colour gradient indicates the number of simulated \revised {uncoded} occurrences. \revised {Note that these runtimes reflect an ideal scenario in which datasets are generated directly under the model, producing relatively smooth diversification dynamics and fewer augmented branches to simulate. Empirical datasets with more complex histories (e.g.\ cetaceans) require substantially longer runtimes; see Table~\ref {tab:models} for empirical values.}\relax }{figure.caption.12}{}}
\newlabel{fig:running-time@cref}{{[figure][5][]5}{[1][17][]20}}
