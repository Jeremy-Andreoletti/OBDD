\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {The data augmentation approach in the OBDD model.} \textbf  {(A)}~The empirical (observed) tree includes coded fossils (brown diamonds) placed in the phylogeny, and uncoded occurrences (orange circles) recorded only as sampling times. \textbf  {(B)}~One complete data-augmented tree, as sampled during a single MCMC iteration. Gray lineages represent augmented branches, including hidden speciation and extinction events, as well as unsampled extant lineages. \textbf  {(C,~D)}~Latent speciation ($\lambda $) and extinction ($\mu $) rates along the augmented tree, where rates are inherited at speciation and then evolve independently along each lineage according to a geometric Brownian motion.\relax }}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:augmented-tree}{{2}{10}{\textbf {The data augmentation approach in the OBDD model.} \textbf {(A)}~The empirical (observed) tree includes coded fossils (brown diamonds) placed in the phylogeny, and uncoded occurrences (orange circles) recorded only as sampling times. \textbf {(B)}~One complete data-augmented tree, as sampled during a single MCMC iteration. Gray lineages represent augmented branches, including hidden speciation and extinction events, as well as unsampled extant lineages. \textbf {(C,~D)}~Latent speciation ($\lambda $) and extinction ($\mu $) rates along the augmented tree, where rates are inherited at speciation and then evolve independently along each lineage according to a geometric Brownian motion.\relax }{figure.caption.5}{}}
\newlabel{fig:augmented-tree@cref}{{[figure][2][]2}{[1][9][]10}}
