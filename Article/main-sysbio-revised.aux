\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Comparison of the diversification models discussed in this paper.} Each column represents a model and each row indicates whether it includes a given feature. Coded fossils are those placed in the phylogeny; uncoded occurrences are fossil sampling times not placed in the phylogeny. Rate heterogeneity refers to branch-specific diversification rates evolving according to a geometric Brownian motion (GBM). Piecewise sampling rates allow fossil sampling rates to vary across user-defined time intervals.\relax }}{6}{table.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:model-comparison}{{1}{6}{\textbf {Comparison of the diversification models discussed in this paper.} Each column represents a model and each row indicates whether it includes a given feature. Coded fossils are those placed in the phylogeny; uncoded occurrences are fossil sampling times not placed in the phylogeny. Rate heterogeneity refers to branch-specific diversification rates evolving according to a geometric Brownian motion (GBM). Piecewise sampling rates allow fossil sampling rates to vary across user-defined time intervals.\relax }{table.caption.1}{}}
\newlabel{tab:model-comparison@cref}{{[table][1][]1}{[1][6][]6}}
\citation{quintero_imbalanced_2024}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The Occurrence Birth-Death Diffusion process.} This figure illustrates a simulation under the OBDD process. One key feature is that speciation and extinction rates are not specified in advance, except for starting values (resp. $\lambda _0$ and $\mu _0$), but instead change gradually along each new branch of the phylogeny. The other important feature is that the sampling process produces {\color  {blue} uncoded} occurrences that are not placed in the phylogeny, in addition to the standard {\color  {blue} coded} fossils. Consequently, each simulation will result in both a sample of rate trajectories (right column, middle) and a phylogeny with fossils and a record of occurrences (right column, resp. brown diamonds and orange circles).\relax }}{7}{figure.caption.2}\protected@file@percent }
\newlabel{fig:obdd-illustration}{{1}{7}{\textbf {The Occurrence Birth-Death Diffusion process.} This figure illustrates a simulation under the OBDD process. One key feature is that speciation and extinction rates are not specified in advance, except for starting values (resp. $\lambda _0$ and $\mu _0$), but instead change gradually along each new branch of the phylogeny. The other important feature is that the sampling process produces \revised {uncoded} occurrences that are not placed in the phylogeny, in addition to the standard \revised {coded} fossils. Consequently, each simulation will result in both a sample of rate trajectories (right column, middle) and a phylogeny with fossils and a record of occurrences (right column, resp. brown diamonds and orange circles).\relax }{figure.caption.2}{}}
\newlabel{fig:obdd-illustration@cref}{{[figure][1][]1}{[1][6][]7}}
