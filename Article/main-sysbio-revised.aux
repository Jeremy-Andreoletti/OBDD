\@writefile{lof}{\contentsline {figure}{\numberline {D.1}{\ignorespaces \textbf  {Drivers of estimation error for OBDD parameters.} This figure displays the drivers of estimation error, measured as the Normalized Mean Squared Error (NMSE). Each column corresponds to a predictor in a Generalized Linear Model:⁡ log of the extant tree size, square root of the number of fossils in the tree, fossils occurrences, and their interaction. Row correspond OBDD model parameters: initial speciation rate ($\lambda _0$), initial extinction rate ($\mu _0$), speciation and extinction trends ($\alpha _{\lambda }$, $\alpha _{\mu }$), diffusion variances ($\sigma _{\lambda }$, $\sigma _{\mu }$), and fossil and occurrence sampling rates for two time intervals ($\psi _1$, $\psi _2$, $\omega _1$, $\omega _2$). The colour of each circle indicates the average multiplicative influence of a predictor on a specific parameter's estimation error, and the circle size also reflects the absolute influence in log scale ($\times 10$ has a similar influence as $\times 1/10$). The shading of each circle reflects the statistical significance (p-value), with darker circles indicating lower p-values (more significant). Predictors with p-values above 0.01 are crossed.\relax }}{45}{figure.caption.25}\protected@file@percent }
\newlabel{fig:NMLE-drivers}{{D.1}{45}{\textbf {Drivers of estimation error for OBDD parameters.} This figure displays the drivers of estimation error, measured as the Normalized Mean Squared Error (NMSE). Each column corresponds to a predictor in a Generalized Linear Model:⁡ log of the extant tree size, square root of the number of fossils in the tree, fossils occurrences, and their interaction. Row correspond OBDD model parameters: initial speciation rate ($\lambda _0$), initial extinction rate ($\mu _0$), speciation and extinction trends ($\alpha _{\lambda }$, $\alpha _{\mu }$), diffusion variances ($\sigma _{\lambda }$, $\sigma _{\mu }$), and fossil and occurrence sampling rates for two time intervals ($\psi _1$, $\psi _2$, $\omega _1$, $\omega _2$). The colour of each circle indicates the average multiplicative influence of a predictor on a specific parameter's estimation error, and the circle size also reflects the absolute influence in log scale ($\times 10$ has a similar influence as $\times 1/10$). The shading of each circle reflects the statistical significance (p-value), with darker circles indicating lower p-values (more significant). Predictors with p-values above 0.01 are crossed.\relax }{figure.caption.25}{}}
\newlabel{fig:NMLE-drivers@cref}{{[figure][1][2147483647,4]D.1}{[1][44][]45}}
\@writefile{lof}{\contentsline {figure}{\numberline {D.2}{\ignorespaces \textbf  {Absolute estimation error as a function of tree size for OBDD parameters.} Each panel displays the absolute error (posterior median $-$ true value) for a model parameter as a function of the total number of tips (extant and fossil) on a log scale, across the 500 simulated datasets. Grey points represent individual datasets, and a LOESS curve (blue) with 95\% confidence band summarizes the trend. Parameters shown are: initial speciation rate ($\lambda _0$), initial extinction rate ($\mu _0$), speciation and extinction trends ($\alpha _{\lambda }$, $\alpha _{\mu }$), diffusion variances ($\sigma _{\lambda }$, $\sigma _{\mu }$), and fossil and occurrence sampling rates for two time intervals ($\psi _1$, $\psi _2$, $\omega _1$, $\omega _2$). LOESS curves near zero indicate unbiased estimation; note the negative bias for diffusion variances and the large scatter in sampling rates for small trees.\relax }}{46}{figure.caption.26}\protected@file@percent }
\newlabel{fig:absolute-error}{{D.2}{46}{\textbf {Absolute estimation error as a function of tree size for OBDD parameters.} Each panel displays the absolute error (posterior median $-$ true value) for a model parameter as a function of the total number of tips (extant and fossil) on a log scale, across the 500 simulated datasets. Grey points represent individual datasets, and a LOESS curve (blue) with 95\% confidence band summarizes the trend. Parameters shown are: initial speciation rate ($\lambda _0$), initial extinction rate ($\mu _0$), speciation and extinction trends ($\alpha _{\lambda }$, $\alpha _{\mu }$), diffusion variances ($\sigma _{\lambda }$, $\sigma _{\mu }$), and fossil and occurrence sampling rates for two time intervals ($\psi _1$, $\psi _2$, $\omega _1$, $\omega _2$). LOESS curves near zero indicate unbiased estimation; note the negative bias for diffusion variances and the large scatter in sampling rates for small trees.\relax }{figure.caption.26}{}}
\newlabel{fig:absolute-error@cref}{{[figure][2][2147483647,4]D.2}{[1][44][]46}}
\@writefile{lof}{\contentsline {figure}{\numberline {D.3}{\ignorespaces \textbf  {Estimation error as a function of the true net diversification trend $\alpha _\lambda - \alpha _\mu $.} Each panel displays the Normalized Mean Squared Error (NMSE) for a model parameter as a function of the true net diversification trend $\alpha _\lambda - \alpha _\mu $ across the 500 simulated OBDD datasets. Orange points represent individual datasets, and a LOESS curve summarizes the trend. The flat LOESS curves indicate no relationship between the speciation trend and estimation accuracy.\relax }}{46}{figure.caption.27}\protected@file@percent }
\newlabel{fig:nmse-vs-net-div-trend}{{D.3}{46}{\textbf {Estimation error as a function of the true net diversification trend $\alpha _\lambda - \alpha _\mu $.} Each panel displays the Normalized Mean Squared Error (NMSE) for a model parameter as a function of the true net diversification trend $\alpha _\lambda - \alpha _\mu $ across the 500 simulated OBDD datasets. Orange points represent individual datasets, and a LOESS curve summarizes the trend. The flat LOESS curves indicate no relationship between the speciation trend and estimation accuracy.\relax }{figure.caption.27}{}}
\newlabel{fig:nmse-vs-net-div-trend@cref}{{[figure][3][2147483647,4]D.3}{[1][45][]46}}
